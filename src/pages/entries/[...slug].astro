---
import { getCollection, render } from "astro:content";
import { statSync } from "fs";
import { resolve } from "path";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("entries", ({ data }) => data.published);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const mdxPath = resolve(`content/entries/${entry.id}.mdx`);
const mdPath = resolve(`content/entries/${entry.id}.md`);
const entryFilePath = (() => {
  try {
    statSync(mdxPath);
    return mdxPath;
  } catch {
    return mdPath;
  }
})();
const updatedAt = statSync(entryFilePath).mtime;

const description = entry.data.book_title
  ? `${entry.data.book_title}${entry.data.author ? ` — ${entry.data.author}` : ""} の読書記録。`
  : `${entry.data.title} の記録。`;
---

<BaseLayout title={entry.data.title} description={description}>
  <a href="/" class="back-link">
    <span class="back-arrow">←</span>
    一覧に戻る
  </a>

  <header class="entry-header">
    <p class="entry-kicker">reading record</p>
    <h1>{entry.data.title}</h1>
    <div class="entry-header-meta">
      {
        entry.data.book_title && (
          <span
            class="entry-book-title meta-stamp meta-stamp--faint"
            data-prefix="書"
          >
            {entry.data.book_title}
          </span>
        )
      }
      {
        entry.data.author && (
          <span
            class="entry-author meta-stamp meta-stamp--muted"
            data-prefix="著"
          >
            {entry.data.author}
          </span>
        )
      }
      <time
        class="entry-date meta-stamp meta-stamp--accent"
        data-prefix="作成"
        datetime={entry.data.date.toISOString()}
      >
        {entry.data.date.toLocaleDateString("ja-JP")}
      </time>
      <time
        class="entry-updated meta-stamp meta-stamp--faint"
        data-prefix="更新"
        datetime={updatedAt.toISOString()}
      >
        {updatedAt.toLocaleDateString("ja-JP")}
      </time>
    </div>
  </header>

  {
    entry.data.cover && entry.data.amazon_url && (
      <a
        href={entry.data.amazon_url}
        class="entry-cover-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <img
          src={entry.data.cover}
          alt={entry.data.book_title ?? entry.data.title}
          class="entry-cover"
        />
      </a>
    )
  }
  {
    entry.data.cover && !entry.data.amazon_url && (
      <img
        src={entry.data.cover}
        alt={entry.data.book_title ?? entry.data.title}
        class="entry-cover"
      />
    )
  }

  <article class="prose">
    <Content />
  </article>

  <p class="entry-colophon" aria-label="記録の終わり">
    <span class="colophon-rule" aria-hidden="true"></span>
    <span class="colophon-text">記録の終わり</span>
    <span class="colophon-rule" aria-hidden="true"></span>
  </p>

  <a href="/" class="back-link back-link--bottom">
    <span class="back-arrow">←</span>
    一覧に戻る
  </a>
</BaseLayout>
