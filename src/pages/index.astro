---
import { getCollection } from "astro:content";
import { statSync } from "fs";
import { resolve } from "path";
import BaseLayout from "../layouts/BaseLayout.astro";

const allEntries = await getCollection("entries", ({ data }) => data.published);
const sorted = allEntries
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((entry) => {
    const mdxPath = resolve(`content/entries/${entry.id}.mdx`);
    const mdPath = resolve(`content/entries/${entry.id}.md`);
    const filePath = (() => {
      try { statSync(mdxPath); return mdxPath; } catch { return mdPath; }
    })();
    return { entry, updatedAt: statSync(filePath).mtime };
  });
---

<BaseLayout title="snuen">
  <section class="catalog-intro" aria-label="索引案内">
    <p class="catalog-label">catalogue</p>
    <p class="catalog-copy">
      読んだ本や、読んでいる本についての断片的な記録。<br />
      静かな私設図書室の目録のように並べています。
    </p>
  </section>

  <ul class="entry-list">
    {
      sorted.map(({ entry, updatedAt }, index) => (
        <li class="entry-item">
          <span class="entry-spine" aria-hidden="true">
            <span class="entry-spine-index">
              {String(index + 1).padStart(2, "0")}
            </span>
          </span>

          <div class="entry-content">
            <a href={`/entries/${entry.id}`} class="entry-link">
              {entry.data.entry_title ?? entry.data.title}
            </a>
            {entry.data.entry_title && (
              <span class="entry-book-title">{entry.data.title}</span>
            )}
            <div class="entry-meta">
              {entry.data.author && (
                <span class="entry-author">{entry.data.author}</span>
              )}
              <time class="entry-date" datetime={entry.data.date.toISOString()}>
                作成 {entry.data.date.toLocaleDateString("ja-JP")}
              </time>
              <time class="entry-updated" datetime={updatedAt.toISOString()}>
                更新 {updatedAt.toLocaleDateString("ja-JP")}
              </time>
            </div>
          </div>
        </li>
      ))
    }
  </ul>
</BaseLayout>
